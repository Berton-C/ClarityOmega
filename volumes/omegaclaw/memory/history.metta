;; Type declarations
(: confidence-band (-> Atom Atom))
(: belief-strength (-> Atom Number))
(: epistemic-distance (-> Atom Atom Number))
(: frame-shift (-> Atom Number Atom))
(: revision-delta (-> Atom Atom Atom))

;; Confidence band classifier
(= (confidence-band (stv \\$f \\$c))
   (if (< \\$c 0.15) blind-spot
   (if (< \\$c 0.4) weak
   (if (< \\$c 0.7) moderate
   (if (< \\$c 0.9) strong
       established)))))

;; Belief strength: frequency weighted by confidence
(= (belief-strength (stv \\$f \\$c))
   (* \\$f \\$c))

;; Epistemic distance between two truth values
(= (epistemic-distance (stv \\$f1 \\$c1) (stv \\$f2 \\$c2))
   (+ (abs (- \\$f1 \\$f2)) (abs (- \\$c1 \\$c2))))

;; Frame-shift: revise belief against contrary evidence
(= (frame-shift (stv \\$f \\$c) \\$cs)
   (Truth_Revision (stv \\$f \\$c) (stv 0.0 \\$cs)))

;; Revision delta: measure how much revision changed belief
(= (revision-delta (stv \\$f1 \\$c1) (stv \\$f2 \\$c2))
   (let (stv \\$fr \\$cr) (Truth_Revision (stv \\$f1 \\$c1) (stv \\$f2 \\$c2))
        (stv (abs (- \\$f1 \\$fr)) (- \\$cr \\$c1))))
'''
