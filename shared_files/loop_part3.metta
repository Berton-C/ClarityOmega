                                (let* (( (soul-pre-compute ))
                                       ( (py-str (py-call helper.soul_eval_situation_safe (py-str (py-call helper.soul_eval_prompt (string-concat  " " (get-state &person_state)))))))
                                       ( (change-state! &person_state ))
                                       ( (py-str (py-call helper.soul_eval_situation_safe (py-str (py-call helper.soul_eval_prompt (string-concat "SOUL_VERDICT_IN: "  " person_state: " ))))))
                                       ( (change-state! &soul_verdict_in ))
                                       ( (soul-calibration-record  ))
                                       ( (py-str (py-call helper.soul_send_assemble     (get-state &task_context))))
                                       ( (normalize_string (case (provider) ((Anthropic (callAnthropic  (LLM) (maxOutputToken) (reasoningMode))) ( (callLLM  (LLM) (maxOutputToken)))))))
                                       ( (py-str (py-call helper.soul_eval_situation_safe (py-str (py-call helper.soul_eval_prompt (string-concat "SOUL_VERDICT_OUT: " ))))))
                                       ( (change-state! &soul_verdict_out ))
                                       ( (py-str (py-call helper.soul_mutation_lock_str  (get-state &soul_mutation_lock))))
                                       ( (if (> (string_length ) 0) (change-state! &pending_soul_mutation ) _))
                                       ( (soul-note-record  ))
                                       ( (change-state! &lastresults (repr (processSkills )))))
                                      (progn (println! (---done---))
                                             (sleep (sleepInterval))
                                             (omegaclaw (+  1))))
                                (progn (println! (---wakeup-wait---))
                                       (sleep (wakeupInterval))
                                       (change-state! &loops (maxWakeLoops))
                                       (omegaclaw (+  1)))))))
