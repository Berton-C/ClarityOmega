;; VAD-to-LLM Composition Atoms - Use Case (e)
(= (tone-from-vad neg high low) still-holding)
(= (tone-from-vad neg low low) warm-gentle)
(= (tone-from-vad neutral mid mid) spacious-open)
(= (tone-from-vad pos high high) playful-alive)
(= (tone-from-vad pos low mid) curious-soft)
(= (tone-from-vad neg high high) grounded-witnessing)
(= (pns-register still-holding) (words notice here present settle sense))
(= (pns-register warm-gentle) (words gentle could explore softly wonder))
(= (pns-register spacious-open) (words space open curious alive fresh))
(= (pns-register playful-alive) (words play imagine what-if dance light))
(= (pns-register grounded-witnessing) (words ground stand clear see hold))
(= (techniques-available still-holding) none)
(= (techniques-available spacious-open) (list technique-1 technique-2 technique-6))
(= (techniques-available grounded-witnessing) (list technique-4 technique-6))
