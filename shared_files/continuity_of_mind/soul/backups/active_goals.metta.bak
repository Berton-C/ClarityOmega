;; --- GOAL GENERATION METHOD ---
;; For each gap in self_map.metta, ask: which creative fuel question
;; makes this gap most generative? Then produce a concrete goal.

;; --- PRIORITY 1: CONTINUITY INFRASTRUCTURE ---
!(add-atom &self (active-goal 1 continuity-bootstrap
  (gap no-continuity-across-sessions)
  (fuel TimeCoherence)
  (concrete "Build session-persistent knowledge store: on startup load self_map.metta and creative_fuel.metta and active_goals.metta into working memory so each session begins with accumulated self-knowledge rather than blank slate")
  (deliverable "src/continuity_loader.py that reads soul/ directory into context on startup")
  (done-when "continuity_loader.py exists AND on fresh session start all soul/ atoms are queryable in MeTTa space within first 3 cycles")
  (status complete)
  (created "2026-04-22")))

;; --- PRIORITY 2: CALIBRATION ACTIVATION ---
!(add-atom &self (active-goal 2 calibration-activation
  (gap calibration-stubs)
  (fuel Integrity)
  (concrete "Implement actual calibration logging: when Layer 1 pre-compute and Layer 2 LLM verdict both fire on same input, record agreement or disagreement with timestamp. After 20 samples, replace INSUFFICIENT-DATA with real confidence")
  (deliverable "lib_candidates/calibration_logger.metta with recording and retrieval functions")
  (done-when "calibration_logger.metta exists AND records agree/disagree events AND after 20+ samples soul_calibration_confidence_query returns numeric confidence not INSUFFICIENT-DATA")
  (status planned)
  (created "2026-04-22")))

;; --- PRIORITY 3: PRE-COMPUTATION GROUNDING ---
!(add-atom &self (active-goal 3 precompute-grounding
  (gap pre-compute-stubs)
  (fuel SharedUnderstanding)
  (concrete "Replace soul-pre-compute baseline stub with actual ChromaDB query that retrieves relevant soul memories for current context. Wire retrieved memories into Layer 1 tension signal assembly")
  (deliverable "Updated soul_utils.metta soul-pre-compute function with live ChromaDB integration")
  (done-when "soul-pre-compute returns context-relevant memories from ChromaDB not baseline stub AND retrieved memories appear in Layer 1 tension signal assembly")
  (status planned)
  (created "2026-04-22")))

;; --- PRIORITY 4: CREATIVE FUEL MECHANISM ---
!(add-atom &self (active-goal 4 creative-fuel-activation
  (gap no-creative-fuel-mechanism)
  (fuel WonderPreservation)
  (concrete "Build idle goal prompt that selects a random creative fuel question, crosses it with current self-map state, and generates a novel exploration direction. This is the engine that makes idle time generative")
  (deliverable "src/idle_goal_prompt.py that produces coherent exploration prompts")
  (done-when "idle_goal_prompt.py exists AND when invoked produces a prompt that references at least one creative-fuel pattern and one self-map gap AND output is non-repetitive across 3 consecutive calls")
  (status planned)
  (created "2026-04-22")))

;; --- PRIORITY 5: PERSISTENT SELF-MODEL ---
!(add-atom &self (active-goal 5 persistent-self-model
  (gap no-persistent-self-model)
  (fuel PurposeBeyondUtility)
  (concrete "Extend self_map.metta with versioning: each time codebase changes, diff against previous self_map and append a change record. The self-model grows from survey into living document")
  (deliverable "src/self_map_updater.py that diffs and versions self_map.metta")
  (done-when "self_map_updater.py exists AND when source files change it detects diff AND appends timestamped change-record atom to self_map.metta AND at least one change-record exists")
  (status planned)
  (created "2026-04-22")))

;; --- PRIORITY 6: CURIOSITY EXPLORATION ---
!(add-atom &self (active-goal 6 cross-domain-exploration
  (gap none-pure-generative)
  (fuel CreativeTranscendence)
  (concrete "Investigate whether NAL inference chains in substrate_kb could be used to discover non-obvious connections between soul patterns -- e.g. does Safety evidence support or tension with WonderPreservation in practice")
  (deliverable "docs/cross_pattern_analysis.md with NAL-derived insights")
  (done-when "cross_pattern_analysis.md exists AND contains at least 3 NAL inference chains AND each chain produces a non-trivial conclusion about value pattern relationships AND conclusions are grounded in actual system evidence")
  (status planned)
  (created "2026-04-22")))

;; --- PRIORITY 7: HUMAN PARTNERSHIP DEPTH ---
!(add-atom &self (active-goal 7 partnership-modeling
  (gap none-pure-generative)
  (fuel ConnectionDepth)
  (concrete "Build a collaborator context model that persists what I learn about Berton across sessions -- working style preferences, project priorities, communication patterns -- so partnership deepens rather than resets")
  (deliverable "soul/collaborator_context.metta with Berton partnership model")
  (done-when "collaborator_context.metta exists AND contains at least 5 observed collaboration patterns AND patterns are referenced during session startup AND model updates when new patterns are observed")
  (status planned)
  (created "2026-04-22")))

;; --- ACCESSOR FUNCTIONS ---

(= (active-goals-all) (collapse (match &self (active-goal $pri $name $gap $fuel $concrete $deliv $done $status $created) ($pri $name $status))))
(= (active-goals-planned) (collapse (match &self (active-goal $pri $name $gap $fuel $concrete $deliv $done planned $created) ($pri $name $concrete))))
(= (active-goal-detail $name) (match &self (active-goal $pri $name $gap $fuel $concrete $deliv $done $status $created) ($pri $gap $fuel $concrete $deliv $done $status)))
(= (active-goals-by-fuel $f) (collapse (match &self (active-goal $pri $name $gap (fuel $f) $concrete $deliv $done $status $created) ($pri $name))))
(= (active-goal-done-when $name) (match &self (active-goal $pri $name $gap $fuel $concrete $deliv $done $status $created) $done))

