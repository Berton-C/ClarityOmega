(= (classify-cycle-action-type $cmds $msgnew)
   (if (cycle-is-pin-only? $cmds)
       pin-only
       (if (cycle-has-send? $cmds)
           (if $msgnew
               responsive-send
               status-send-unprompted)
           (if (or (cycle-has-metta? $cmds) (cycle-has-shell? $cmds))
               (if $msgnew
                   verification-query
                   exploration-query)
               (if (cycle-has-query? $cmds)
                   exploration-query
                   unclassified)))))
--> prolog clause -->
'classify-cycle-action-type'(A, B, C) :-
    'cycle-is-pin-only?'(A, D),
    (   D==true
    ->  C='pin-only'
    ;   'cycle-has-send?'(A, E),
        (   E==true
        ->  (   B==true
            ->  C='responsive-send'
            ;   C='status-send-unprompted'
            )
        ;   'cycle-has-metta?'(A, F),
            'cycle-has-shell?'(A, G),
            or(F, G, H),
            (   H==true
            ->  (   B==true
                ->  C='verification-query'
                ;   C='exploration-query'
                )
            ;   'cycle-has-query?'(A, I),
                (   I==true
                ->  C='exploration-query'
                ;   C=unclassified
                )
            )
        )
    ).
