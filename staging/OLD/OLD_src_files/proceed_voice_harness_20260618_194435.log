(= (cycle-is-pin-only? $cmds)
   (and (cycle-has-pin? $cmds)
        (and (not (cycle-has-send? $cmds))
             (and (not (cycle-has-metta? $cmds))
                  (and (not (cycle-has-query? $cmds))
                       (not (cycle-has-shell? $cmds)))))))
--> prolog clause -->
'cycle-is-pin-only?'(A, B) :-
    'cycle-has-pin?'(A, C),
    'cycle-has-send?'(A, D),
    not(D, E),
    'cycle-has-metta?'(A, F),
    not(F, G),
    'cycle-has-query?'(A, H),
    not(H, I),
    'cycle-has-shell?'(A, J),
    not(J, K),
    and(I, K, L),
    and(G, L, M),
    and(E, M, N),
    and(C, N, B).
