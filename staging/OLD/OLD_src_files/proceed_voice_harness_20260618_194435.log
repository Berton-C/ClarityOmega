        (   E==true
        ->  (   B==true
            ->  C='responsive-send'
            ;   C='status-send-unprompted'
            )
        ;   'cycle-has-metta?'(A, F),
            'cycle-has-shell?'(A, G),
            or(F, G, H),
            (   H==true
            ->  (   B==true
                ->  C='verification-query'
                ;   C='exploration-query'
                )
            ;   'cycle-has-query?'(A, I),
                (   I==true
                ->  C='exploration-query'
                ;   C=unclassified
                )
            )
        )
    ).
