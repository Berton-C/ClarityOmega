    'cycle-has-pin?'(A, C),
    'cycle-has-send?'(A, D),
    not(D, E),
    'cycle-has-metta?'(A, F),
    not(F, G),
    'cycle-has-query?'(A, H),
    not(H, I),
    'cycle-has-shell?'(A, J),
    not(J, K),
