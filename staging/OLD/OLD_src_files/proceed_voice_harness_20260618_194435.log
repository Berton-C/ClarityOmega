'soul-rationality-startup-check'(['append-file', A, B]) :-
    C=['soul-rationality-gaps'],
    B=D,
    ==(C, [], E),
    (   E==true
    ->  D="SOUL-AUDIT: all soul values have causal procedures -- structurally sound"
    ;   repr(C, F),
        'py-call'([ 'helper.concat_strings',
                    "SOUL-AUDIT: WARNING -- orphaned soul values: ",
                    F
                  ],
                  D)
    ),
    'println!'(B, _),
    'py-call'(['helper.file_exists_int', "./memory/soul_audit_log.txt"], G),
    ==(G, 1, H),
    (   H==true
    ->  true
    ;   true,
        library(omegaclaw, './memory/soul_audit_log.txt', _)
    ),
    library(omegaclaw, './memory/soul_audit_log.txt', A).
