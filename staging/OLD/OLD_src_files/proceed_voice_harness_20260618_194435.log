(= (classify-cycle-action-type $cmds $msgnew)
   (if (cycle-is-pin-only? $cmds)
       pin-only
       (if (cycle-has-send? $cmds)
           (if $msgnew
               responsive-send
               status-send-unprompted)
           (if (or (cycle-has-metta? $cmds) (cycle-has-shell? $cmds))
               (if $msgnew
                   verification-query
                   exploration-query)
               (if (cycle-has-query? $cmds)
                   exploration-query
                   unclassified)))))
