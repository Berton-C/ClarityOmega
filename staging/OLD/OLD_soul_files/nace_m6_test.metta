(rule-health-class healthy (stv 1.0 0.9))
(rule-health-class declining (stv 0.5 0.9))
(rule-health-class orphan (stv 0.0 0.9))
(rule-orphan-threshold 3)
(rule-declining-threshold 2)
(rule-divergence-count rule-alpha 1)
(rule-divergence-count rule-beta 3)(= (rule-health-from-count $count) (if (>= $count (rule-orphan-threshold)) orphan (if (>= $count (rule-declining-threshold)) declining healthy)))
(= (nace-update-truth-values) (match &self (rule-divergence-count $rule-name $count) (let $class (rule-health-from-count $count) (match &self (rule-health-class $class (stv $strength $confidence)) (rule-stv $rule-name (stv $strength $confidence))))))
!(nace-update-truth-values)
